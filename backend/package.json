{
  "name": "agent-orchestrator-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup-db": "node scripts/setup-db.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "dev:all": "concurrently -n back,front -c cyan,magenta \"npm run dev\" \"npm run dev --prefix ../frontend\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "knex": "^3.1.0",
    "mysql2": "^3.22.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
